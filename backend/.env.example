APP_NAME=Huanto API
APP_ENV=dev
API_V1_PREFIX=/api/v1
PUBLIC_BASE_URL=
ADMIN_API_KEY=
LOG_LEVEL=INFO
LOG_JSON=true
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.0
RATE_LIMIT_ENABLED=true
RATE_LIMIT_GLOBAL_PER_MINUTE=120
RATE_LIMIT_AUTH_PER_MINUTE=30
RATE_LIMIT_TASK_EXECUTE_PER_MINUTE=20

DATABASE_URL=postgresql+psycopg://huanto_app:HuantoDev%402026@127.0.0.1:5433/huanto

IMAGE_RETENTION_DAYS=7
POINTS_SIGNUP_BONUS=100
POINTS_DAILY_BONUS=10
POINTS_TXT2IMG_COST=20
POINTS_IMG2IMG_COST=18
POINTS_STYLE_TRANSFER_COST=22

AUTH_LOGIN_MODE=mock
AUTH_ALLOW_DEBUG_USER_HEADER=true
AUTH_ACCEPT_MOCK_TOKEN=false
AUTH_FORCE_DISABLE_DEBUG_USER_HEADER_IN_PROD=true
AUTH_FORCE_DISABLE_MOCK_TOKEN_IN_PROD=true
JWT_SECRET_KEY=change_me_in_production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=120
JWT_REFRESH_TOKEN_EXPIRE_DAYS=14
WECHAT_API_BASE=https://api.weixin.qq.com
WECHAT_APPID=
WECHAT_APP_SECRET=

AI_PROVIDER_DEFAULT=mock
