<view class="page-shell">
  <view class="float-glow glow-peach"></view>
  <view class="float-glow glow-cream"></view>

  <view class="edit-nav" style="{{navStyle}}">
    <view class="edit-nav-back" bindtap="onBack">←</view>
    <view class="edit-nav-center">
      <view class="edit-nav-title">AI 幻头</view>
      <view class="edit-nav-subtitle">一句话智能修改你的头像</view>
    </view>
    <view class="edit-nav-help" bindtap="onHelpTap">?</view>
  </view>

  <view class="container image-edit-page">
    <view class="preview-section">
      <view wx:if="{{inputImageUrl}}" class="avatar-preview-card">
        <image class="preview-image" mode="aspectFill" src="{{inputImageUrl}}" />
        <view class="avatar-edit-badge">修</view>
      </view>
      <view wx:else class="avatar-preview-card avatar-preview-empty" bindtap="chooseAndUpload">
        <view class="upload-icon">传</view>
        <view class="title-md">上传头像开始编辑</view>
        <view class="subtitle mt-12">先上传并裁成正方形头像，再进行智能修改。</view>
      </view>

      <view class="preview-action-row">
        <button class="preview-action preview-action-ghost" bindtap="chooseAndUpload">重新上传</button>
        <button class="preview-action preview-action-primary" bindtap="recropCurrent">裁剪</button>
      </view>
    </view>

    <view class="soft-card reference-card">
      <view class="reference-head">
        <view class="reference-title">参考图设置（可选）</view>
        <view class="reference-tip">i</view>
      </view>
      <view class="reference-body">
        <view class="reference-upload-box" bindtap="chooseReferenceImage">
          <image wx:if="{{referenceImageUrl}}" class="preview-image" mode="aspectFill" src="{{referenceImageUrl}}" />
          <view wx:else class="reference-upload-empty">
            <view class="reference-upload-icon">图</view>
            <view class="reference-upload-text">点击上传</view>
          </view>
        </view>

        <view class="reference-copy">
          <view class="reference-text">
            结合文字指令，AI 将参考此图的<text class="reference-highlight">构图、光影及特征</text>进行修改。
          </view>
          <view class="reference-format">支持 JPG/PNG/HEIC 格式</view>
        </view>
      </view>
    </view>

    <view class="quick-section">
      <view class="quick-section-title">快速编辑</view>
      <scroll-view scroll-x class="quick-scroll" enable-flex="true">
        <block wx:for="{{quickActions}}" wx:key="key">
          <view class="quick-pill {{selectedQuickAction===item.key ? 'quick-pill-active' : ''}}" data-key="{{item.key}}" bindtap="onQuickActionTap">
            <view class="quick-pill-icon">{{item.glyph}}</view>
            <view class="quick-pill-text">{{item.title}}</view>
          </view>
        </block>
      </scroll-view>
    </view>

    <view class="soft-card command-card">
      <view class="command-title">智能指令</view>
      <view class="command-box">
        <textarea
          class="textarea-box command-textarea"
          value="{{prompt}}"
          bindinput="onPromptInput"
          placeholder="例如：换成短发，海滩背景"
          placeholder-style="color:#a5b2c8;"
        />
        <button class="command-send" bindtap="onCreateTask">></button>
      </view>

      <view class="command-hint-wrap">
        <block wx:for="{{promptHints}}" wx:key="id">
          <view class="command-hint" data-id="{{item.id}}" bindtap="onPromptHintTap">{{item.label}}</view>
        </block>
      </view>

      <view wx:if="{{errorMsg}}" class="subtitle mt-16">{{errorMsg}}</view>
    </view>
  </view>

  <view class="edit-action-bar">
    <button class="edit-submit-btn" loading="{{submitting}}" bindtap="onCreateTask">开始智能编辑</button>
    <view class="edit-cost-tip">本次编辑将消耗 {{rules.img2img_cost}} 幻豆 (余额: {{pointsBalance}})</view>
  </view>
</view>
