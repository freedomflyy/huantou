.edit-nav {
  position: sticky;
  top: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 28rpx 18rpx;
  background: rgba(255, 248, 243, 0.92);
  border-bottom: 1px solid rgba(242, 223, 207, 0.9);
  backdrop-filter: blur(18rpx);
  box-sizing: border-box;
}

.edit-nav-back,
.edit-nav-help {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f56a21;
  font-size: 38rpx;
  font-weight: 700;
}

.edit-nav-center {
  flex: 1;
  text-align: center;
}

.edit-nav-title {
  color: #17141f;
  font-size: 44rpx;
  font-weight: 700;
}

.edit-nav-subtitle {
  margin-top: 6rpx;
  color: #f0874f;
  font-size: 24rpx;
}

.image-edit-page {
  padding-top: 28rpx;
  padding-bottom: 240rpx;
}

.preview-section {
  padding: 10rpx 14rpx 0;
}

.avatar-preview-card {
  position: relative;
  width: 420rpx;
  height: 420rpx;
  margin: 0 auto;
  border-radius: 42rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #ffe8d8 0%, #ffd7c0 100%);
  border: 8rpx solid rgba(245, 106, 33, 0.08);
  box-shadow: 0 18rpx 34rpx rgba(226, 141, 84, 0.14);
}

.avatar-preview-empty {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 36rpx;
  box-sizing: border-box;
}

.avatar-edit-badge {
  position: absolute;
  right: -14rpx;
  bottom: -12rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff7a1f 0%, #f56a21 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 18rpx 28rpx rgba(245, 106, 33, 0.24);
}

.preview-action-row {
  display: flex;
  gap: 20rpx;
  margin-top: 34rpx;
}

.preview-action {
  flex: 1;
  height: 98rpx;
  line-height: 98rpx;
  border-radius: 24rpx;
  font-size: 34rpx;
  font-weight: 700;
  border: 1px solid rgba(242, 223, 207, 0.95);
}

.preview-action::after,
.command-send::after,
.edit-submit-btn::after {
  border: none;
}

.preview-action-ghost {
  background: #fff1e8;
  color: #f56a21;
}

.preview-action-primary {
  background: linear-gradient(135deg, #ff7a1f 0%, #f56a21 100%);
  color: #ffffff;
  box-shadow: 0 16rpx 28rpx rgba(245, 106, 33, 0.2);
}

.reference-card {
  margin-top: 34rpx;
}

.reference-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 18rpx;
}

.reference-title {
  color: #6f819b;
  font-size: 34rpx;
  font-weight: 700;
}

.reference-tip {
  width: 34rpx;
  height: 34rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 106, 33, 0.14);
  color: #f0874f;
  font-size: 20rpx;
  font-weight: 700;
}

.reference-body {
  display: flex;
  align-items: center;
  gap: 22rpx;
}

.reference-upload-box {
  width: 168rpx;
  height: 168rpx;
  flex-shrink: 0;
  border-radius: 26rpx;
  overflow: hidden;
  border: 3rpx dashed rgba(245, 106, 33, 0.22);
  background: #fff8f2;
}

.reference-upload-empty {
  width: 100%;
  height: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #f29a6e;
}

.reference-upload-icon {
  width: 54rpx;
  height: 54rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 106, 33, 0.14);
  color: #f56a21;
  font-size: 24rpx;
  font-weight: 700;
}

.reference-upload-text {
  margin-top: 12rpx;
  font-size: 22rpx;
  font-weight: 600;
}

.reference-copy {
  flex: 1;
}

.reference-text {
  color: #6f819b;
  font-size: 24rpx;
  line-height: 1.75;
}

.reference-highlight {
  color: #f56a21;
  font-weight: 700;
}

.reference-format {
  margin-top: 14rpx;
  color: #c6b7ae;
  font-size: 20rpx;
}

.quick-section {
  margin-top: 34rpx;
}

.quick-section-title,
.command-title {
  margin: 0 6rpx 20rpx;
  color: #6f819b;
  font-size: 38rpx;
  font-weight: 700;
}

.quick-scroll {
  white-space: nowrap;
  padding-bottom: 8rpx;
}

.quick-pill {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  padding: 0 28rpx;
  margin-right: 18rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(242, 223, 207, 0.95);
  background: rgba(255, 255, 255, 0.92);
  box-shadow: 0 10rpx 24rpx rgba(222, 136, 72, 0.06);
  color: #17141f;
}

.quick-pill-active {
  border-color: rgba(245, 106, 33, 0.24);
  background: #fff6ee;
}

.quick-pill-icon {
  width: 40rpx;
  height: 40rpx;
  border-radius: 999rpx;
  margin-right: 10rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(245, 106, 33, 0.12);
  color: #f56a21;
  font-size: 20rpx;
  font-weight: 700;
}

.quick-pill-text {
  font-size: 28rpx;
  font-weight: 600;
}

.command-card {
  margin-top: 34rpx;
}

.command-box {
  position: relative;
}

.command-textarea {
  min-height: 210rpx;
  padding-right: 116rpx;
  background: #f4f7fb;
  border-color: rgba(232, 236, 242, 0.95);
}

.command-send {
  position: absolute;
  right: 20rpx;
  bottom: 20rpx;
  width: 84rpx;
  height: 84rpx;
  line-height: 84rpx;
  padding: 0;
  border-radius: 24rpx;
  background: linear-gradient(135deg, #ff7a1f 0%, #f56a21 100%);
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  box-shadow: 0 16rpx 28rpx rgba(245, 106, 33, 0.22);
}

.command-hint-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
  margin-top: 24rpx;
}

.command-hint {
  height: 58rpx;
  line-height: 58rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  border: 1px solid rgba(245, 106, 33, 0.22);
  background: #fffaf6;
  color: #f56a21;
  font-size: 24rpx;
  font-weight: 600;
}

.edit-action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 40;
  padding: 18rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-top: 1px solid rgba(242, 223, 207, 0.95);
  backdrop-filter: blur(20rpx);
}

.edit-submit-btn {
  width: 100%;
  height: 108rpx;
  line-height: 108rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #ff7a1f 0%, #f45d13 100%);
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 700;
  box-shadow: 0 24rpx 36rpx rgba(245, 106, 33, 0.26);
}

.edit-cost-tip {
  margin-top: 16rpx;
  text-align: center;
  color: #9c8d85;
  font-size: 24rpx;
}
