.text-nav {
  position: sticky;
  top: 0;
  z-index: 30;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: calc(18rpx + env(safe-area-inset-top)) 28rpx 18rpx;
  background: rgba(255, 248, 243, 0.92);
  border-bottom: 1px solid rgba(242, 223, 207, 0.9);
  backdrop-filter: blur(18rpx);
  box-sizing: border-box;
}

.text-nav-back,
.text-nav-space {
  width: 72rpx;
  height: 72rpx;
}

.text-nav-back {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #f56a21;
  font-size: 36rpx;
  font-weight: 700;
}

.text-nav-title {
  color: #17141f;
  font-size: 42rpx;
  font-weight: 700;
}

.text-generate-page {
  padding-top: 24rpx;
  padding-bottom: 280rpx;
}

.text-hero {
  padding: 34rpx 10rpx 20rpx;
  text-align: center;
}

.text-hero-title {
  color: #17141f;
  font-size: 72rpx;
  line-height: 1.12;
  font-weight: 700;
}

.text-hero-subtitle {
  margin-top: 16rpx;
  color: #667792;
  font-size: 28rpx;
}

.prompt-card {
  margin-top: 18rpx;
}

.prompt-head,
.text-section-title,
.collapse-title-wrap {
  display: flex;
  align-items: center;
}

.prompt-head {
  margin-bottom: 18rpx;
}

.prompt-icon,
.section-icon,
.collapse-icon {
  width: 42rpx;
  height: 42rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 12rpx;
  background: rgba(245, 106, 33, 0.12);
  color: #f56a21;
  font-size: 20rpx;
  font-weight: 700;
}

.prompt-title,
.collapse-title {
  color: #17141f;
  font-size: 34rpx;
  font-weight: 700;
}

.prompt-textarea {
  min-height: 188rpx;
  background: #f8f6f6;
  border-color: rgba(242, 223, 207, 0.75);
}

.prompt-chip-wrap {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 22rpx;
}

.prompt-chip {
  padding: 0 22rpx;
  height: 56rpx;
  line-height: 56rpx;
  border-radius: 999rpx;
  background: #fff1e8;
  color: #f56a21;
  font-size: 22rpx;
  font-weight: 600;
}

.text-section-head,
.history-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin: 34rpx 2rpx 20rpx;
}

.style-scroll {
  white-space: nowrap;
  padding-bottom: 10rpx;
}

.style-card-lite {
  display: inline-block;
  width: 210rpx;
  margin-right: 18rpx;
  text-align: center;
}

.style-card-media {
  width: 210rpx;
  height: 210rpx;
  border-radius: 26rpx;
  overflow: hidden;
  border: 2rpx solid rgba(242, 223, 207, 0.95);
  background: linear-gradient(180deg, #ffe8d4 0%, #ffd1b8 100%);
  box-sizing: border-box;
}

.style-card-lite-active .style-card-media {
  border-color: #f56a21;
  box-shadow: 0 16rpx 28rpx rgba(245, 106, 33, 0.12);
}

.style-card-name {
  margin-top: 14rpx;
  color: #17141f;
  font-size: 24rpx;
  font-weight: 600;
}

.style-none-mark {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #8fa0bc;
  font-size: 54rpx;
  font-weight: 700;
  background: linear-gradient(180deg, #edf2fb 0%, #dfe8f5 100%);
}

.collapse-card {
  margin-top: 26rpx;
  padding: 0;
  overflow: hidden;
}

.collapse-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 28rpx 28rpx;
}

.collapse-arrow {
  color: #95a4be;
  font-size: 28rpx;
  transform: rotate(0deg);
  transition: transform 0.2s ease;
}

.collapse-arrow-open {
  transform: rotate(180deg);
}

.collapse-body {
  padding: 0 28rpx 28rpx;
}

.segment-wrap {
  display: flex;
  gap: 12rpx;
}

.segment-pill {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  border-radius: 20rpx;
  text-align: center;
  background: #fff8f2;
  border: 1px solid rgba(242, 223, 207, 0.95);
  color: #7b6a60;
  font-size: 24rpx;
  font-weight: 600;
}

.segment-pill-active {
  background: #fff1e6;
  border-color: rgba(245, 106, 33, 0.26);
  color: #f56a21;
}

.hair-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.hair-dot {
  width: 56rpx;
  height: 56rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.hair-dot-active {
  border-color: #f56a21;
  box-shadow: 0 0 0 6rpx rgba(245, 106, 33, 0.08);
}

.hair-dot-inner {
  width: 100%;
  height: 100%;
  border-radius: 999rpx;
  border: 4rpx solid rgba(255, 255, 255, 0.96);
  box-sizing: border-box;
}

.setting-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 4rpx 0 8rpx;
}

.setting-label {
  color: #17141f;
  font-size: 26rpx;
  font-weight: 600;
}

.setting-value {
  color: #8e7b70;
  font-size: 24rpx;
}

.advanced-textarea {
  min-height: 148rpx;
}

.history-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.history-card {
  border-radius: 28rpx;
  overflow: hidden;
  border: 2rpx solid rgba(242, 223, 207, 0.95);
  background: rgba(255, 255, 255, 0.92);
}

.history-card-active {
  border-color: #f56a21;
  box-shadow: 0 18rpx 28rpx rgba(245, 106, 33, 0.12);
}

.history-card-media {
  height: 314rpx;
  position: relative;
  overflow: hidden;
  background: linear-gradient(180deg, #ffe8d4 0%, #ffd1b8 100%);
}

.history-selected-mark {
  position: absolute;
  right: 14rpx;
  top: 14rpx;
  height: 42rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: rgba(245, 106, 33, 0.92);
  color: #ffffff;
  font-size: 20rpx;
  line-height: 42rpx;
  font-weight: 700;
}

.history-empty {
  text-align: center;
  margin-top: 10rpx;
}

.history-action-row {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.history-action {
  flex: 1;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 24rpx;
  font-size: 30rpx;
  font-weight: 700;
  border: 1px solid rgba(242, 223, 207, 0.95);
  background: rgba(255, 255, 255, 0.9);
  color: #17141f;
}

.history-action::after,
.generate-btn::after {
  border: none;
}

.history-action-primary {
  background: #fff1e8;
  color: #f56a21;
  border-color: rgba(245, 106, 33, 0.14);
}

.history-action-ghost {
  background: rgba(255, 255, 255, 0.92);
}

.page-error {
  text-align: center;
}

.generate-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 40;
  padding: 18rpx 28rpx calc(28rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  border-top: 1px solid rgba(242, 223, 207, 0.95);
  backdrop-filter: blur(20rpx);
}

.generate-tip {
  margin-bottom: 14rpx;
  text-align: center;
  color: #8e7b70;
  font-size: 22rpx;
}

.generate-btn {
  width: 100%;
  height: 104rpx;
  line-height: 104rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7a1f 0%, #f45d13 100%);
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
  box-shadow: 0 22rpx 34rpx rgba(245, 106, 33, 0.24);
}
