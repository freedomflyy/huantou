.decorate-page {
  padding-bottom: 300rpx;
}

.decorate-hero {
  padding-top: 32rpx;
  background:
    radial-gradient(circle at 50% 0%, rgba(255, 226, 211, 0.88), transparent 58%),
    linear-gradient(180deg, rgba(255, 249, 245, 0.98), rgba(255, 255, 255, 0.94));
}

.preview-wrap {
  width: 380rpx;
  margin: 0 auto;
  position: relative;
  padding: 12rpx;
}

.preview-ring {
  position: absolute;
  inset: 0;
  border-radius: 999rpx;
  border: 4rpx dashed rgba(245, 106, 33, 0.18);
  animation: ring-rotate 30s linear infinite;
}

.preview-avatar {
  position: relative;
  width: 356rpx;
  height: 356rpx;
  margin: 0 auto;
  border-radius: 999rpx;
  background: linear-gradient(180deg, #edf2ec 0%, #dbe5d7 100%);
  border: 10rpx solid rgba(255, 255, 255, 0.96);
  box-shadow: 0 26rpx 48rpx rgba(199, 120, 71, 0.16);
  overflow: hidden;
}

.avatar-placeholder {
  width: 100%;
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
  background:
    linear-gradient(135deg, rgba(255, 244, 236, 0.95), rgba(240, 245, 236, 0.92));
}

.placeholder-badge {
  min-width: 116rpx;
  height: 56rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  border: 2rpx dashed rgba(245, 106, 33, 0.3);
  color: #b68f76;
  font-size: 22rpx;
  line-height: 56rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.76);
}

.tool-badge {
  position: absolute;
  right: 6rpx;
  bottom: 10rpx;
  width: 92rpx;
  height: 92rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, #ff7a1f 0%, #f45d13 100%);
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 18rpx 34rpx rgba(245, 106, 33, 0.24);
}

.decorate-tabs {
  display: flex;
  margin: 12rpx 0 8rpx;
  background: rgba(255, 255, 255, 0.7);
  border-bottom: 1px solid rgba(242, 223, 207, 0.9);
}

.decorate-tab {
  flex: 1;
  height: 98rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  color: #98a7bd;
  font-size: 28rpx;
  font-weight: 600;
  position: relative;
}

.decorate-tab-active {
  color: #f56a21;
  font-weight: 700;
}

.decorate-tab-active::after {
  content: "";
  position: absolute;
  left: 34rpx;
  right: 34rpx;
  bottom: 0;
  height: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7a1f 0%, #f56a21 100%);
}

.decorate-tab-glyph {
  font-size: 26rpx;
  font-weight: 700;
}

.decorate-body {
  margin-top: 18rpx;
}

.decorate-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 18rpx;
}

.decorate-tile {
  min-height: 144rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 249, 244, 0.92));
  border: 1px solid rgba(242, 223, 207, 0.92);
  box-shadow: 0 14rpx 28rpx rgba(223, 151, 93, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-direction: column;
}

.recent-tile {
  min-height: 150rpx;
}

.tile-mark {
  width: 64rpx;
  height: 64rpx;
  border-radius: 22rpx;
  background: rgba(245, 106, 33, 0.08);
  color: #f56a21;
  font-size: 30rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.sticker-tile {
  padding: 16rpx 10rpx;
  box-sizing: border-box;
}

.tile-empty {
  width: 84rpx;
  height: 84rpx;
  border-radius: 24rpx;
  border: 2rpx dashed rgba(245, 106, 33, 0.2);
  background: rgba(255, 246, 240, 0.78);
}

.tile-label {
  margin-top: 12rpx;
  color: #aa8a74;
  font-size: 20rpx;
}

.decorate-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.decorate-row {
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 249, 244, 0.92));
  border: 1px solid rgba(242, 223, 207, 0.92);
}

.font-sample {
  width: 92rpx;
  height: 92rpx;
  border-radius: 26rpx;
  background: rgba(255, 244, 236, 0.88);
  color: #f56a21;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.frame-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 20rpx;
}

.frame-card {
  padding: 22rpx 16rpx;
  border-radius: 28rpx;
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.98), rgba(255, 249, 244, 0.92));
  border: 1px solid rgba(242, 223, 207, 0.92);
  box-shadow: 0 14rpx 28rpx rgba(223, 151, 93, 0.08);
}

.frame-preview {
  height: 176rpx;
  border-radius: 28rpx;
  background: rgba(255, 248, 242, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
}

.frame-circle {
  width: 116rpx;
  height: 116rpx;
  border-radius: 999rpx;
  border: 8rpx solid rgba(245, 106, 33, 0.22);
  box-shadow: inset 0 0 0 8rpx rgba(255, 255, 255, 0.86);
}

.decorate-bottom {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  z-index: 30;
}

.category-scroll {
  padding: 14rpx 0 10rpx;
  background: rgba(255, 255, 255, 0.88);
  border-top: 1px solid rgba(242, 223, 207, 0.9);
  backdrop-filter: blur(18rpx);
}

.category-row {
  display: inline-flex;
  padding: 0 28rpx;
  gap: 16rpx;
}

.category-pill {
  flex-shrink: 0;
  min-width: 110rpx;
  height: 64rpx;
  padding: 0 24rpx;
  border-radius: 999rpx;
  background: rgba(255, 243, 236, 0.98);
  color: #d07f52;
  font-size: 24rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.category-pill-active {
  background: linear-gradient(135deg, #ff7a1f 0%, #f56a21 100%);
  color: #ffffff;
  box-shadow: 0 12rpx 26rpx rgba(245, 106, 33, 0.2);
}

.decorate-actions {
  display: flex;
  gap: 18rpx;
  padding: 18rpx 28rpx 28rpx;
  background: rgba(255, 247, 241, 0.96);
  border-top: 1px solid rgba(242, 223, 207, 0.9);
  backdrop-filter: blur(18rpx);
}

.decorate-reset {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
}

.decorate-save {
  flex: 1.7;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 28rpx;
  font-size: 30rpx;
}

.center {
  text-align: center;
}

@keyframes ring-rotate {
  from {
    transform: rotate(0deg);
  }
  to {
    transform: rotate(360deg);
  }
}
