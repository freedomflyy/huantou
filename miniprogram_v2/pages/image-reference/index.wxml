<view class="page-shell style-transfer-page">
  <view class="float-glow glow-peach"></view>
  <view class="float-glow glow-cream"></view>

  <view class="style-header">
    <view class="style-back" bindtap="onBack">←</view>
    <view class="style-header-copy">
      <view class="style-header-title">风格迁移</view>
      <view class="style-header-subtitle">上传照片，选择风格，一键生成头像</view>
    </view>
  </view>

  <scroll-view scroll-y class="style-scroll-shell">
    <view class="style-body">
      <view class="upload-card">
        <view class="portrait-stage" bindtap="onPortraitTap">
          <image wx:if="{{inputImageUrl}}" class="portrait-image" mode="aspectFill" src="{{inputImageUrl}}" />
          <view wx:else class="portrait-empty">
            <view class="portrait-empty-badge">传</view>
            <view class="portrait-empty-title">上传并裁剪头像</view>
            <view class="portrait-empty-copy">先裁成正方形头像，再开始风格迁移</view>
          </view>
        </view>
        <view class="upload-actions">
          <button class="upload-action" bindtap="uploadInput">重新上传</button>
          <button class="upload-action" bindtap="recropCurrent">裁剪图片</button>
        </view>
      </view>

      <view class="section-row">
        <view class="section-title">选择风格</view>
        <view class="section-badge">更多风格持续更新</view>
      </view>

      <scroll-view scroll-x class="style-card-scroll" enable-flex="true">
        <view class="style-card-row">
          <block wx:for="{{styleCards}}" wx:key="id">
            <view class="style-pick-card" data-style="{{item.name}}" bindtap="onStyleTap">
              <view class="style-pick-cover {{selectedStyle===item.name ? 'style-pick-cover-active' : ''}}">
                <image wx:if="{{item.imageUrl}}" class="style-pick-image" mode="aspectFill" src="{{item.imageUrl}}" />
                <view wx:else class="style-pick-fallback {{item.coverClass}}"></view>
                <view wx:if="{{selectedStyle===item.name}}" class="style-pick-check">✓</view>
              </view>
              <view class="style-pick-name">{{item.name}}</view>
              <view class="style-pick-desc">{{item.desc}}</view>
            </view>
          </block>
        </view>
      </scroll-view>

      <view class="setting-card">
        <view class="setting-block">
          <view class="setting-head">
            <view class="setting-label">风格强度</view>
            <view class="setting-value">{{styleStrength}}%</view>
          </view>
          <slider
            class="style-slider"
            min="35"
            max="100"
            step="1"
            value="{{styleStrength}}"
            activeColor="#ec5b13"
            backgroundColor="#f5e7de"
            block-color="#ec5b13"
            block-size="20"
            bindchange="onStrengthChange"
          />
        </view>

        <view class="setting-divider"></view>

        <view class="toggle-row">
          <view>
            <view class="setting-label">保留面部特征</view>
            <view class="toggle-copy">使生成的头像更像本人</view>
          </view>
          <switch
            checked="{{preserveFace}}"
            color="#ec5b13"
            bindchange="onPreserveFaceChange"
          />
        </view>
      </view>

      <view class="queue-note">
        <view class="queue-note-dot">i</view>
        <view class="queue-note-copy">生成任务为异步处理，预计需要 30 秒。完成后您可以在“我的作品”或“任务列表”中查看并下载结果。</view>
      </view>

      <view wx:if="{{errorMsg}}" class="queue-error">{{errorMsg}}</view>
    </view>
  </scroll-view>

  <view class="style-footer">
    <button class="queue-button" loading="{{submitting}}" bindtap="onCreateTask">
      <view class="queue-button-title">加入生成队列</view>
      <view class="queue-button-subtitle">消耗 {{rules.style_transfer_cost}} 灵感点</view>
    </button>
  </view>
</view>
