<view class="page-shell">
  <view class="float-glow glow-peach"></view>
  <view class="float-glow glow-cream"></view>

  <view class="container fixed-tab-space create-page" style="{{pageTopStyle}}">
    <view class="create-topbar">
      <view class="create-back" bindtap="onBack">←</view>
      <view class="create-top-title">开始创作</view>
      <view class="create-top-space"></view>
    </view>

    <view class="create-hero">
      <view class="create-hero-title">释放你的想象力</view>
      <view class="create-hero-subtitle">使用 AI 开启全新创作之旅</view>
    </view>

    <view class="create-section-title">核心功能</view>
    <view class="feature-matrix">
      <block wx:for="{{features}}" wx:key="key">
        <view class="feature-matrix-card" data-key="{{item.key}}" bindtap="onFeatureTap">
          <view class="feature-matrix-icon {{item.tone}}">{{item.glyph}}</view>
          <view class="feature-matrix-title">{{item.title}}</view>
          <view class="feature-matrix-note">{{item.note}}</view>
        </view>
      </block>
    </view>

    <view class="create-inspiration-head">
      <view class="create-section-title inspiration-title">灵感展示</view>
      <view class="section-more" bindtap="goSquare">查看全部</view>
    </view>

    <scroll-view scroll-x class="inspiration-scroll" enable-flex="true">
      <block wx:for="{{inspirations}}" wx:key="id">
        <view class="inspiration-card" data-title="{{item.title}}" bindtap="onInspirationTap">
          <view class="inspiration-cover {{item.coverClass}}">
            <image wx:if="{{item.imageUrl}}" class="preview-image" mode="aspectFill" src="{{item.imageUrl}}" />
          </view>
          <view class="inspiration-title-text">{{item.title}}</view>
        </view>
      </block>
    </scroll-view>

    <bottom-tab current="create" />
  </view>
</view>
