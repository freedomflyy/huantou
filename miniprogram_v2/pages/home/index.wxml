<view class="page-shell">
  <view class="float-glow glow-peach"></view>
  <view class="float-glow glow-cream"></view>

  <view class="home-fixed-head">
    <view class="container home-fixed-inner" style="{{headerStyle}}">
      <view class="home-topbar">
        <view class="home-mark">
          <image wx:if="{{brandingLogoUrl}}" class="home-mark-image" mode="aspectFill" src="{{brandingLogoUrl}}" />
          <view wx:else>幻</view>
        </view>
        <view class="home-header-title">Phantom</view>
        <view class="home-profile-btn" bindtap="goProfile">我</view>
      </view>
    </view>
  </view>

  <view class="container fixed-tab-space home-body">
    <view class="home-fixed-space" style="{{headerSpacerStyle}}"></view>

    <view class="hero-shell">
      <swiper class="hero-swiper" circular="true" current="{{currentHeroIndex}}" bindchange="onHeroChange">
        <block wx:for="{{heroSlides}}" wx:key="id">
          <swiper-item>
            <view class="hero-slide {{!item.imageUrl ? item.coverClass : ''}}" data-style="{{item.styleName}}" bindtap="onHeroSlideTap">
              <image wx:if="{{item.imageUrl}}" class="hero-slide-image" mode="aspectFill" src="{{item.imageUrl}}" />
              <view class="hero-slide-mask"></view>
              <view class="hero-slide-content">
                <view class="hero-badge">{{item.badge}}</view>
                <view class="hero-title">{{item.title}}</view>
                <view class="hero-copy">{{item.desc}}</view>
                <button class="hero-btn" data-style="{{item.styleName}}" catchtap="onHeroCtaTap">
                  {{item.ctaText}} →
                </button>
              </view>
            </view>
          </swiper-item>
        </block>
      </swiper>

      <view class="hero-dots">
        <block wx:for="{{heroSlides}}" wx:key="id">
          <view class="hero-dot {{currentHeroIndex===index ? 'hero-dot-active' : ''}}"></view>
        </block>
      </view>
    </view>

    <view class="quick-actions-row">
      <block wx:for="{{quickActions}}" wx:key="key">
        <view class="quick-entry" data-key="{{item.key}}" bindtap="onQuickActionTap">
          <view class="quick-entry-box">
            <view class="quick-entry-glyph">{{item.glyph}}</view>
          </view>
          <view class="quick-entry-label">{{item.title}}</view>
        </view>
      </block>
    </view>

    <view class="section-head home-section-head plaza-head">
      <view class="title-lg">广场精选</view>
      <view class="plaza-tabs">
        <block wx:for="{{plazaTabs}}" wx:key="*this">
          <view class="plaza-tab {{currentPlazaTab===item ? 'plaza-tab-active' : ''}}" data-tab="{{item}}" bindtap="onPlazaTabTap">{{item}}</view>
        </block>
      </view>
    </view>

    <view class="plaza-grid">
      <block wx:for="{{displayGallery}}" wx:key="id">
        <view class="plaza-card" data-taskid="{{item.taskId}}" bindtap="onGalleryTap">
          <view class="plaza-cover {{item.coverClass}}">
            <image wx:if="{{item.imageUrl}}" class="preview-image" mode="aspectFill" src="{{item.imageUrl}}" />
          </view>
          <view class="plaza-body">
            <view class="plaza-title">{{item.title}}</view>
            <view class="plaza-author-row">
              <view class="plaza-avatar-dot"></view>
              <view class="plaza-author">{{item.creatorName}}</view>
            </view>
          </view>
        </view>
      </block>
    </view>

    <button class="square-entry-btn" bindtap="goSquare">进入广场探索更多 ›</button>

    <bottom-tab current="home" />
  </view>
</view>
