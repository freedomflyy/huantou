.home-fixed-head {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 25;
  background: rgba(255, 248, 242, 0.92);
  backdrop-filter: blur(18rpx);
}

.home-fixed-inner {
  padding-bottom: 12rpx;
}

.home-fixed-space {
  height: 162rpx;
}

.home-body {
  padding-top: 0;
}

.home-brand-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.brand-wrap {
  display: flex;
  align-items: center;
  gap: 18rpx;
}

.brand-badge {
  width: 82rpx;
  height: 82rpx;
  border-radius: 24rpx;
  background: rgba(245, 106, 33, 0.1);
  color: #f56a21;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.brand-title {
  font-size: 44rpx;
  font-weight: 700;
  color: #201914;
}

.brand-accent {
  color: #f56a21;
  font-size: 30rpx;
  font-weight: 500;
}

.brand-subtitle {
  margin-top: 8rpx;
  color: #6f7686;
  font-size: 22rpx;
}

.head-actions {
  display: flex;
  gap: 14rpx;
}

.head-icon-btn {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  background: rgba(249, 229, 216, 0.7);
  color: #5d6779;
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(255, 255, 255, 0.72);
}

.home-section-head {
  margin-top: 4rpx;
  margin-bottom: 22rpx;
}

.home-kicker {
  margin-top: 8rpx;
  color: #f56a21;
  font-size: 22rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
}

.template-scroll {
  white-space: nowrap;
  margin-bottom: 36rpx;
}

.template-show-card {
  display: inline-block;
  width: 460rpx;
  margin-right: 18rpx;
  border-radius: 34rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(242, 223, 207, 0.98);
  box-shadow: 0 16rpx 34rpx rgba(225, 146, 92, 0.12);
}

.template-show-cover {
  position: relative;
  height: 614rpx;
  overflow: hidden;
}

.template-cover-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0) 42%, rgba(0, 0, 0, 0.32) 100%);
}

.template-tag {
  position: absolute;
  left: 22rpx;
  bottom: 22rpx;
  height: 44rpx;
  padding: 0 16rpx;
  border-radius: 16rpx;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  backdrop-filter: blur(10rpx);
  border: 1px solid rgba(255, 255, 255, 0.2);
}

.template-show-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 22rpx;
}

.template-add-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7a1f 0%, #f56a21 100%);
  color: #ffffff;
  font-size: 38rpx;
  line-height: 64rpx;
  text-align: center;
  flex-shrink: 0;
}

.text-banner-card {
  position: relative;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 300rpx;
  padding: 34rpx 34rpx 30rpx;
  margin-bottom: 32rpx;
  border-radius: 32rpx;
  background: linear-gradient(135deg, rgba(252, 231, 243, 0.92), rgba(249, 229, 216, 0.96));
  border: 1px solid rgba(255, 255, 255, 0.8);
  box-shadow: 0 16rpx 34rpx rgba(225, 146, 92, 0.12);
}

.text-banner-copy {
  position: relative;
  z-index: 2;
  width: 68%;
}

.text-banner-icon {
  position: absolute;
  right: 36rpx;
  bottom: 18rpx;
  color: rgba(245, 106, 33, 0.18);
  font-size: 140rpx;
  font-weight: 700;
}

.banner-action-btn {
  min-width: 196rpx;
  height: 76rpx;
  padding: 0 28rpx;
  margin: 28rpx 0 0;
  border: none;
  border-radius: 999rpx;
  background: #151b2e;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
}

.banner-action-btn::after {
  border: none;
}

.feature-row {
  display: flex;
  gap: 18rpx;
  margin-bottom: 36rpx;
}

.feature-card {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 24rpx 20rpx;
  border-radius: 28rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(242, 223, 207, 0.92);
}

.feature-icon {
  width: 68rpx;
  height: 68rpx;
  border-radius: 18rpx;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.tone-blue {
  background: rgba(216, 230, 255, 0.9);
  color: #3a70d6;
}

.tone-purple {
  background: rgba(232, 220, 255, 0.9);
  color: #8d54df;
}

.feature-title {
  color: #201914;
  font-size: 26rpx;
  font-weight: 700;
}

.feature-note {
  margin-top: 6rpx;
  color: #8b8178;
  font-size: 20rpx;
}

.plaza-head {
  margin-bottom: 20rpx;
}

.plaza-tabs {
  display: flex;
  gap: 24rpx;
}

.plaza-tab {
  position: relative;
  padding-bottom: 10rpx;
  color: #b0b7c6;
  font-size: 26rpx;
  font-weight: 700;
}

.plaza-tab-active {
  color: #f56a21;
}

.plaza-tab-active::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4rpx;
  border-radius: 999rpx;
  background: #f56a21;
}

.plaza-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.plaza-card {
  overflow: hidden;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(242, 223, 207, 0.92);
  box-shadow: 0 16rpx 28rpx rgba(225, 146, 92, 0.08);
}

.plaza-cover {
  height: 300rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #ffe8d4 0%, #ffd1b8 100%);
}

.plaza-body {
  padding: 16rpx 18rpx 18rpx;
}

.plaza-title {
  color: #1f1814;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.plaza-author-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.plaza-avatar-dot {
  width: 26rpx;
  height: 26rpx;
  border-radius: 999rpx;
  background: #d7dee9;
}

.plaza-author {
  color: #7b8596;
  font-size: 22rpx;
}

.square-entry-btn {
  width: auto;
  margin: 28rpx auto 0;
  padding: 0 18rpx;
  border: none;
  background: transparent;
  color: #f56a21;
  font-size: 28rpx;
  font-weight: 700;
}

.square-entry-btn::after {
  border: none;
}
