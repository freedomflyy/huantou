.home-fixed-head {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 25;
  background: rgba(255, 249, 244, 0.94);
  backdrop-filter: blur(18rpx);
  border-bottom: 1px solid rgba(242, 223, 207, 0.9);
}

.home-fixed-inner {
  padding-bottom: 18rpx;
}

.home-fixed-space {
  height: 166rpx;
}

.home-body {
  padding-top: 0;
}

.home-topbar {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.home-mark {
  width: 76rpx;
  height: 76rpx;
  border-radius: 24rpx;
  background: rgba(245, 106, 33, 0.1);
  color: #f56a21;
  font-size: 34rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.home-mark-image {
  width: 100%;
  height: 100%;
}

.home-header-title {
  flex: 1;
  text-align: center;
  color: #17141f;
  font-size: 52rpx;
  font-weight: 700;
}

.home-profile-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 999rpx;
  background: rgba(245, 106, 33, 0.1);
  color: #f56a21;
  font-size: 26rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 1px solid rgba(242, 223, 207, 0.92);
}

.home-section-head {
  margin-top: 0;
  margin-bottom: 22rpx;
}

.hero-shell {
  margin-bottom: 46rpx;
}

.hero-swiper {
  height: 468rpx;
}

.hero-slide {
  position: relative;
  height: 468rpx;
  border-radius: 34rpx;
  overflow: hidden;
  background: linear-gradient(135deg, #1d1a18 0%, #3e2818 45%, #0e0f13 100%);
  box-shadow: 0 22rpx 42rpx rgba(29, 21, 16, 0.18);
}

.hero-slide-image {
  width: 100%;
  height: 100%;
}

.hero-slide-mask {
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, rgba(0, 0, 0, 0.12) 0%, rgba(0, 0, 0, 0.44) 100%);
}

.hero-slide-content {
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 36rpx;
  box-sizing: border-box;
}

.hero-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  min-width: 118rpx;
  height: 56rpx;
  padding: 0 22rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7a1f 0%, #f56a21 100%);
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 700;
}

.hero-title {
  margin-top: 22rpx;
  color: #ffffff;
  font-size: 62rpx;
  line-height: 1.08;
  font-weight: 700;
}

.hero-copy {
  margin-top: 14rpx;
  max-width: 82%;
  color: rgba(255, 255, 255, 0.86);
  font-size: 30rpx;
  line-height: 1.55;
}

.hero-btn {
  min-width: 216rpx;
  height: 84rpx;
  padding: 0 30rpx;
  margin: 28rpx 0 0;
  border: none;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ff7a1f 0%, #f56a21 100%);
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 16rpx 28rpx rgba(245, 106, 33, 0.22);
}

.hero-btn::after {
  border: none;
}

.hero-dots {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  margin-top: 18rpx;
}

.hero-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 999rpx;
  background: rgba(245, 106, 33, 0.24);
}

.hero-dot-active {
  width: 14rpx;
  height: 14rpx;
  background: #f56a21;
}

.quick-actions-row {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 42rpx;
}

.quick-entry {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.quick-entry-box {
  width: 126rpx;
  height: 126rpx;
  border-radius: 34rpx;
  background: linear-gradient(180deg, #fff1e8 0%, #fff7f2 100%);
  border: 1px solid rgba(242, 223, 207, 0.96);
  box-shadow: 0 12rpx 24rpx rgba(225, 146, 92, 0.08);
  display: flex;
  align-items: center;
  justify-content: center;
}

.quick-entry-glyph {
  color: #f56a21;
  font-size: 42rpx;
  font-weight: 700;
}

.quick-entry-label {
  margin-top: 18rpx;
  color: #17141f;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1.3;
  text-align: center;
}

.plaza-head {
  margin-bottom: 20rpx;
}

.plaza-tabs {
  display: flex;
  gap: 24rpx;
}

.plaza-tab {
  position: relative;
  padding-bottom: 10rpx;
  color: #b0b7c6;
  font-size: 26rpx;
  font-weight: 700;
}

.plaza-tab-active {
  color: #f56a21;
}

.plaza-tab-active::after {
  content: "";
  position: absolute;
  left: 0;
  right: 0;
  bottom: 0;
  height: 4rpx;
  border-radius: 999rpx;
  background: #f56a21;
}

.plaza-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.plaza-card {
  overflow: hidden;
  border-radius: 26rpx;
  background: rgba(255, 255, 255, 0.95);
  border: 1px solid rgba(242, 223, 207, 0.92);
  box-shadow: 0 16rpx 28rpx rgba(225, 146, 92, 0.08);
}

.plaza-cover {
  height: 300rpx;
  overflow: hidden;
  background: linear-gradient(180deg, #ffe8d4 0%, #ffd1b8 100%);
}

.plaza-body {
  padding: 16rpx 18rpx 18rpx;
}

.plaza-title {
  color: #1f1814;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.4;
}

.plaza-author-row {
  display: flex;
  align-items: center;
  gap: 10rpx;
  margin-top: 14rpx;
}

.plaza-avatar-dot {
  width: 26rpx;
  height: 26rpx;
  border-radius: 999rpx;
  background: #d7dee9;
}

.plaza-author {
  color: #7b8596;
  font-size: 22rpx;
}

.square-entry-btn {
  width: auto;
  margin: 28rpx auto 0;
  padding: 0 18rpx;
  border: none;
  background: transparent;
  color: #f56a21;
  font-size: 28rpx;
  font-weight: 700;
}

.square-entry-btn::after {
  border: none;
}
