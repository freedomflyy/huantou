.home-head {
  margin-bottom: 20rpx;
}

.brand-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.brand-mark {
  width: 72rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #ff9f78 0%, #f56a21 100%);
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  box-shadow: 0 14rpx 26rpx rgba(245, 106, 33, 0.22);
}

.brand-title {
  font-size: 40rpx;
  font-weight: 700;
  line-height: 1.14;
}

.brand-subtitle {
  margin-top: 6rpx;
  color: #8d786d;
  font-size: 22rpx;
}

.head-action {
  width: 68rpx;
  height: 68rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: rgba(255, 255, 255, 0.88);
  color: #f56a21;
  font-size: 26rpx;
  font-weight: 700;
  border: 1px solid rgba(242, 223, 207, 0.95);
}
