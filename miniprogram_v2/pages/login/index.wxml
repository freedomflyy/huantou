<view class="page-shell">
  <view class="login-bg-glow login-bg-main"></view>
  <view class="login-bg-glow login-bg-accent-1"></view>
  <view class="login-bg-glow login-bg-accent-2"></view>

  <view class="container login-shell">
    <view class="login-brand-block">
      <view class="login-brand-avatar" bindtap="handleLogoTap">
        <image wx:if="{{brandingLogoUrl}}" class="login-brand-avatar-image" mode="aspectFill" src="{{brandingLogoUrl}}" />
        <view wx:else class="login-brand-avatar-fallback">幻</view>
      </view>
      <view class="login-brand-title" bindtap="handleLogoTap">幻头</view>
      <view class="login-brand-subtitle">让每一张头像都充满艺术感</view>
    </view>

    <view class="login-form-block">
      <button class="login-wechat-btn" loading="{{submitting}}" bindtap="handlePrimaryLogin">
        <view class="login-wechat-inner">
          <view class="login-wechat-icon">微</view>
          <view>微信一键登录</view>
        </view>
      </button>

      <view class="login-secondary-row">
        <view class="login-secondary-link" data-type="phone" bindtap="onSecondaryTap">手机号登录</view>
        <view class="login-secondary-divider"></view>
        <view class="login-secondary-link" data-type="other" bindtap="onSecondaryTap">其他登录方式</view>
      </view>
    </view>

    <view class="login-legal-block">
      <view class="login-check-row" bindtap="toggleAgreement">
        <view class="login-check-box {{agreed ? 'login-check-box-active' : ''}}">
          <view wx:if="{{agreed}}" class="login-check-mark">✓</view>
        </view>
        <view class="login-legal-copy">
          我已阅读并同意
          <text class="login-legal-link" catchtap="openTerms">《用户服务协议》</text>
          、
          <text class="login-legal-link" catchtap="openPrivacy">《隐私保护政策》</text>
          以及相关授权条款
        </view>
      </view>
      <view wx:if="{{errorMsg}}" class="login-error-text">{{errorMsg}}</view>
      <view class="login-engine-tag">AI AVATAR GENERATION ENGINE V2.0</view>
    </view>
  </view>

  <view wx:if="{{profileSheetVisible}}" class="login-sheet-mask" catchtap="closeProfileSheet">
    <view class="login-sheet-panel" catchtap="noop">
      <view class="login-sheet-title">完善微信资料</view>
      <view class="login-sheet-subtitle">首次登录需要选择头像并填写昵称，后续会自动记住。</view>

      <button class="login-sheet-avatar" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
        <image wx:if="{{profileAvatarUrl || brandingLogoUrl}}" class="login-sheet-avatar-image" mode="aspectFill" src="{{profileAvatarUrl || brandingLogoUrl}}" />
        <view wx:else class="login-sheet-avatar-fallback">幻</view>
        <view class="login-sheet-avatar-tag">选择头像</view>
      </button>

      <input
        class="login-sheet-input"
        type="nickname"
        maxlength="20"
        placeholder="请输入昵称"
        value="{{profileNickname}}"
        bindinput="onNicknameInput"
      />

      <view class="login-sheet-actions">
        <button class="login-sheet-cancel" bindtap="closeProfileSheet">稍后再说</button>
        <button class="login-sheet-confirm" loading="{{submitting}}" bindtap="enterApp">确认并登录</button>
      </view>
    </view>
  </view>

  <view wx:if="{{reviewSheetVisible}}" class="login-sheet-mask" catchtap="closeReviewSheet">
    <view class="login-sheet-panel" catchtap="noop">
      <view class="login-sheet-title">测试账号入口</view>
      <view class="login-sheet-subtitle">请输入审核测试账号与密码，进入固定测试账号。</view>

      <input
        class="login-sheet-input"
        maxlength="32"
        placeholder="请输入测试账号"
        value="{{reviewUsername}}"
        bindinput="onReviewUsernameInput"
      />

      <input
        class="login-sheet-input"
        password="true"
        maxlength="32"
        placeholder="请输入测试密码"
        value="{{reviewPassword}}"
        bindinput="onReviewPasswordInput"
      />

      <view class="login-sheet-actions">
        <button class="login-sheet-cancel" bindtap="closeReviewSheet">取消</button>
        <button class="login-sheet-confirm" loading="{{submitting}}" bindtap="handleReviewLogin">进入测试账号</button>
      </view>
    </view>
  </view>
</view>
